<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedSupli - Plan Payment</title>
    <script src="https://js.stripe.com/v3/"></script>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        }
        .card-shadow {
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }
        .btn-primary {
            background-color: #10b981;
            transition: all 0.3s ease;
            color: white;
            font-weight: bold;
        }
        .btn-primary:hover {
            background-color: #059669;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.1);
        }
        #card-element {
            padding: 1rem;
            border: 2px solid #e1e8ed;
            border-radius: 0.75rem;
            background: #ffffff;
        }
        #card-element.StripeElement--focus {
            border-color: #10b981;
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-lg p-8 bg-white rounded-3xl card-shadow">
        <h1 class="text-4xl font-extrabold text-green-800 mb-2 text-center">MedSupli</h1>
        <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Plan Upgrade</h2>

        <div class="mb-8 p-6 bg-green-50 rounded-2xl border border-green-100">
            <h3 class="text-lg font-bold text-green-900 mb-2">Selected Plan</h3>
            <div class="flex justify-between items-center bg-white p-4 rounded-xl shadow-sm">
                <div>
                    <p class="text-sm text-gray-500 uppercase tracking-widest font-semibold"><%= planType %></p>
                    <p class="text-xl font-extrabold text-gray-800"><%= planName %></p>
                </div>
                <div class="text-right">
                    <p class="text-3xl font-extrabold text-green-600">$<%= planPrice %></p>
                </div>
            </div>
        </div>

        <form id="payment-form" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Secure Card Payment</label>
                <div id="card-element"></div>
                <div id="card-errors" class="text-red-500 text-sm mt-3 font-medium"></div>
            </div>

            <input type="hidden" name="userId" id="userId" value="<%= userId %>" />
            <input type="hidden" name="plan_id" id="plan_id" value="<%= plan_id %>" />

            <button type="submit" id="submit-btn" class="w-full btn-primary py-4 px-4 rounded-2xl shadow-md flex items-center justify-center gap-3">
                <i class="fas fa-lock"></i> Pay and Activate Plan
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center">
            <p class="text-gray-400 text-sm flex items-center justify-center gap-2">
                <i class="fas fa-shield-alt"></i> Securely processed by Stripe
            </p>
        </div>
    </div>

    <script>
        const stripe = Stripe('<%= publishableKey %>');
        const elements = stripe.elements();
        const card = elements.create('card', {
            style: {
                base: {
                    fontSize: '16px',
                    color: '#32325d',
                    fontFamily: '"Inter", sans-serif',
                    '::placeholder': { color: '#aab7c4' },
                },
                invalid: { color: '#fa755a', iconColor: '#fa755a' },
            },
            hidePostalCode: true
        });
        card.mount('#card-element');

        const form = document.getElementById('payment-form');
        const errorDiv = document.getElementById('card-errors');
        const submitBtn = document.getElementById('submit-btn');

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            errorDiv.textContent = '';
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

            const { token, error } = await stripe.createToken(card);

            if (error) {
                errorDiv.textContent = error.message;
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-lock"></i> Pay and Activate Plan';
                return;
            }

            const payload = {
                stripeToken: token.id,
                userId: document.getElementById('userId').value,
                plan_id: document.getElementById('plan_id').value
            };

            try {
                const response = await fetch('/medsupli/pay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Plan Activated!',
                        text: 'Your payment was successful and your plan has been activated.',
                        timer: 3000,
                        timerProgressBar: true,
                        showConfirmButton: false,
                        didClose: () => { location.href = "/success"; }
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Payment Failed',
                        text: result.message || 'There was an error processing your payment.',
                        confirmButtonColor: '#10b981'
                    });
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-lock"></i> Pay and Activate Plan';
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'System Error',
                    text: 'Unable to process payment at this time.',
                    confirmButtonColor: '#10b981'
                });
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-lock"></i> Pay and Activate Plan';
            }
        });
    </script>
</body>
</html>
